# 見本。実際の値は Streamlit Community Cloud の App settings → Secrets に貼る
# （このファイルはコミット可＝値のないテンプレ。実 secrets.toml はコミットしない）。

# Supabase（Project settings → API から）
SUPABASE_URL = "https://xxxxxxxx.supabase.co"
SUPABASE_KEY = "eyJ...（anon public key でOK）"

# Google Maps（Maps JavaScript API 有効・リファラ制限したキー）
GOOGLE_MAPS_API_KEY = "AIza..."

# Google AI Studio（Gemini 2.5 Flash・名刺OCR用・無料枠でOK）
# https://aistudio.google.com/apikey で発行
GEMINI_API_KEY = "AIza..."

# 任意：合言葉ロック（空なら誰でも閲覧編集）
APP_PASSWORD = ""
